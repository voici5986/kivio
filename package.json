{
  "name": "kivio",
  "private": true,
  "version": "2.7.3",
  "description": "Kivio - Screen-level AI assistant for macOS and Windows",
  "license": "GPL-3.0-or-later",
  "author": "ZM",
  "type": "module",
  "scripts": {
    "dev": "(npm run build:swift || true) && tauri dev",
    "dev:ui": "vite --port 5713",
    "build": "npm run build:swift && tauri build",
    "tauri": "tauri",
    "prepare:pyodide": "node scripts/prepare-pyodide-assets.mjs",
    "build:ui": "npm run prepare:pyodide && vite build",
    "build:swift": "node scripts/build-swift-sidecar.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lobehub/icons": "^5.10.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@types/katex": "^0.16.8",
    "katex": "^0.16.28",
    "lucide-react": "^0.561.0",
    "mermaid": "^11.15.0",
    "pyodide": "^0.26.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "virtua": "^0.49.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vitest": "^2.1.9"
  },
  "main": "dist/index.html"
}
